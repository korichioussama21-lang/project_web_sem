{
  "name": "kg-desktop",
  "version": "1.0.0",
  "description": "Knowledge Graph Desktop Application",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc",
    "package": "electron-builder",
    "start": "npm run dev"
  },
  "keywords": [
    "electron",
    "knowledge-graph"
  ],
  "author": "Knowledge Graph Team",
  "license": "MIT",
  "dependencies": {
    "@kg/core": "file:../../packages/core",
    "@kg/rdf": "file:../../packages/rdf",
    "@kg/ontology": "file:../../packages/ontology",
    "@kg/sparql": "file:../../packages/sparql",
    "@kg/reasoning": "file:../../packages/reasoning",
    "@kg/visualization": "file:../../packages/visualization",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.kg.desktop",
    "productName": "Knowledge Graph Desktop",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
